# Example environment variables for local development.
# Copy this file to .dev.vars and fill in your actual secrets.

# ============================================================
# AUTH (next-auth v5)
# ============================================================
AUTH_SECRET="your-auth-secret-min-32-chars"
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ============================================================
# GOOGLE CLOUD STORAGE
# ============================================================
GCS_PROJECT_ID="your-gcp-project-id"
GCS_BUCKET_NAME="your-gcs-bucket-name"
GCS_CLIENT_EMAIL="your-gcs-service-account-email"
# Note: The private key needs to be wrapped in quotes and have newlines escaped (\\n)
GCS_PRIVATE_KEY="your-gcs-private-key"

# ============================================================
# PADDLE PAYMENTS
# ============================================================
PADDLE_ENVIRONMENT="sandbox"
PADDle_API_KEY="your-paddle-api-key"
PADDLE_WEBHOOK_SECRET="your-paddle-webhook-secret"

# ============================================================
# DITBLOGS SDK
# ============================================================
DITBLOGS_API_KEY="your-ditblogs-api-key"
RESEND_API_KEY=""
