{
  "name": "tempfile",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:open": "opennextjs-cloudflare build",
    "start": "next start",
    "lint": "next lint",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "db:migrate:local": "wrangler d1 migrations apply tempfile-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply tempfile-db --remote",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@auth/core": "^0.39.0",
    "@auth/drizzle-adapter": "^1.7.4",
    "@dishistech/blogs-sdk": "*",
    "@marsidev/react-turnstile": "^1.4.2",
    "@opennextjs/cloudflare": "^1.4.0",
    "@scalar/api-reference-react": "^0.9.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.44.2",
    "framer-motion": "^12.19.0",
    "lucide-react": "^0.511.0",
    "nanoid": "^5.1.5",
    "next": "15.3.9",
    "next-auth": "5.0.0-beta.29",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hot-toast": "^2.5.2",
    "react-icons": "^5.5.0",
    "resend": "^6.9.3",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.25.64"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9.29.0",
    "eslint-config-next": "15.3.9",
    "postcss": "^8.5.5",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.23.0"
  }
}
