# .env.example
# Copy this to .env.local for local development
# Secrets go in .dev.vars for Cloudflare Workers local dev

# ============================================================
# APPLICATION
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=TempFile

# ============================================================
# AUTH (next-auth v5)
# ============================================================
AUTH_SECRET=your-auth-secret-min-32-chars-run-openssl-rand-base64-32
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# GitHub OAuth App
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Google OAuth App
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================================
# GOOGLE CLOUD STORAGE
# ============================================================
GCS_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=tempfile-uploads-dev

# Service account JSON key (stringified)
# Create at: https://console.cloud.google.com/iam-admin/serviceaccounts
# Grant: Storage Object Admin on your bucket
GCS_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# ============================================================
# PADDLE PAYMENTS
# ============================================================
PADDLE_ENVIRONMENT=sandbox
PADDLE_API_KEY=your-paddle-api-key
PADDLE_WEBHOOK_SECRET=your-paddle-webhook-secret

# Plan price IDs from Paddle dashboard
PADDLE_STARTER_MONTHLY_ID=pri_xxx
PADDLE_STARTER_YEARLY_ID=pri_xxx
PADDLE_PRO_MONTHLY_ID=pri_xxx
PADDLE_PRO_YEARLY_ID=pri_xxx
PADDLE_ENTERPRISE_MONTHLY_ID=pri_xxx
PADDLE_ENTERPRISE_YEARLY_ID=pri_xxx

# ============================================================
# DITBLOGS SDK
# ============================================================
DITBLOGS_API_KEY=your-ditblogs-api-key

# ============================================================
# CLOUDFLARE (for local dev via wrangler)
# ============================================================
# These are simulated locally by wrangler
# CF_ACCOUNT_ID=your-cloudflare-account-id

# ============================================================
# LIMITS (override defaults)
# ============================================================
MAX_FREE_FILE_SIZE=104857600   # 100 MB
MAX_PRO_FILE_SIZE=2147483648   # 2 GB
FREE_EXPIRY_HOURS=24
PRO_EXPIRY_DAYS=30
