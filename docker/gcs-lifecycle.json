{
  "rule": [
    {
      "action": {
        "type": "SetStorageClass",
        "storageClass": "NEARLINE"
      },
      "condition": {
        "age": 1,
        "matchesPrefix": ["files/"],
        "numNewerVersions": 1
      }
    },
    {
      "action": {
        "type": "Delete"
      },
      "condition": {
        "age": 2,
        "matchesPrefix": ["files/"]
      }
    }
  ]
}
